<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/nav_graph"
    app:startDestination="@id/haulFragment">

    <fragment
        android:id="@+id/haulFragment"
        android:name="com.android.shawnclisby.tilt.HaulFragment"
        android:label="HaulFragment" >
        <action
            android:id="@+id/action_haulFragment_to_haulDetailFragment"
            app:destination="@id/haulDetailFragment"
            app:enterAnim="@anim/from_right"
            app:exitAnim="@anim/to_left"
            app:popEnterAnim="@anim/from_left"
            app:popExitAnim="@anim/to_right" />
    </fragment>
    <fragment
        android:id="@+id/haulDetailFragment"
        android:name="com.android.shawnclisby.tilt.HaulDetailFragment"
        android:label="HaulDetailFragment" />
</navigation>